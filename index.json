BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:0:3","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"什么是tag标签？ Tag 标签：VLAN 标签是一个加在数据帧上的“身份证”，标明它属于哪个 VLAN，方便交换机识别和分发。 正篇： ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:0:4","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"Access端口 通常连接到终端设备（计算机、打印机等）只属于一个VLAN。 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:0:5","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"工作机制 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:1:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"1.接收数据帧： ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:2:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"Access端口接收的以太网帧通常是无vlan标签的（untagged） 交换机会为收到的无标签帧自动打上Access口配置的pvid（默认vlan id）将其归属到对应的vlan 若收到带有标签的帧（tagged）Access端口通常会丢弃，因为极大多数情况下它只处理无标签帧。 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:2:1","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"2.发送数据帧： Access端口发送的数据帧会去除VLAN标签，以普通以太网数据帧（untagged）形式发送给终端设备。因为大多数终端设备不能处理有tagged的数据帧。 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:3:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"Trunk 端口是在交换机中用于处理多个VLAN流量的一种端口模式。它可以同时承载多个VLAN。通常用于连接交换机之间、交换机与路由器，或支持 VLAN 的设备（如服务器）。通过 **VLAN 标签（802.1Q）**区分不同 VLAN 的流量。 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:3:1","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"工作机制 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:4:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"1.接收数据帧： 有标签帧（Untagged Frames）： 接收到的帧带有 802.1Q 标签（4 字节，包含 VLAN ID，如 VLAN 10）。 交换机根据 VLAN ID 将帧转发到对应 VLAN。 无标签帧（Untagged Frames）： 如果收到无标签帧，Trunk 端口会将其归到 **Native VLAN **（中文翻译一般为本征VLAN，通常是 VLAN 1，可手动配置）。 例如：无标签帧收到后，分配到 VLAN 1。 ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:5:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"2.发送数据帧： ","date":"2025-05-21","objectID":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/:6:0","tags":["Hugo","GithubPages","Blog"],"title":"交换机常见端口模式Access、Hybrid、Trunk 区别","uri":"/posts/%E4%BA%A4%E6%8D%A2%E6%9C%BA%E5%B8%B8%E8%A7%81%E7%AB%AF%E5%8F%A3%E6%A8%A1%E5%BC%8Faccesshybridtrunk-%E5%8C%BA%E5%88%AB/"},{"categories":["Blog"],"content":"windows系统0成本通过Github仓库托管Hugo静态网站生成器最后通过cloudflare自定义域名搭建个人blog","date":"2025-05-21","objectID":"/posts/windows%E5%9F%BA%E4%BA%8Ehugo--github-pages--cloudflare%E6%90%AD%E5%BB%BA%E4%B8%AA%E4%BA%BA%E5%8D%9A%E5%AE%A2%E4%BA%8C/","tags":["Hugo","GithubPages","Blog"],"title":"Windows基于Hugo + GitHub Pages + Cloudflare搭建个人博客（二）","uri":"/posts/windows%E5%9F%BA%E4%BA%8Ehugo--github-pages--cloudflare%E6%90%AD%E5%BB%BA%E4%B8%AA%E4%BA%BA%E5%8D%9A%E5%AE%A2%E4%BA%8C/"},{"categories":["Blog"],"content":"在上一章本地运行hugo后我们将它推送到github仓库托管。 ","date":"2025-05-21","objectID":"/posts/windows%E5%9F%BA%E4%BA%8Ehugo--github-pages--cloudflare%E6%90%AD%E5%BB%BA%E4%B8%AA%E4%BA%BA%E5%8D%9A%E5%AE%A2%E4%BA%8C/:1:0","tags":["Hugo","GithubPages","Blog"],"title":"Windows基于Hugo + GitHub Pages + Cloudflare搭建个人博客（二）","uri":"/posts/windows